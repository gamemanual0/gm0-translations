#: ../../gm0/source/docs/awards/award-types.rst:60
msgid ""
"Team must be positive and inclusive, and each team member contribute to the "
"success of the team."
msgstr ""
"El equipo debe ser positivo e inclusivo, y cada uno de sus miembros debe "
"contribuir al éxito del equipo."

#: ../../gm0/source/docs/awards/award-types.rst:62
#: ../../gm0/source/docs/awards/award-types.rst:182
